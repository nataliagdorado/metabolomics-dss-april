package dss;
unit Stage5Unit;

import dss.ScoredAnnotation;
import dss.Annotation;
import dss.Compound;

rule "Elution Order: Positive Evidence"
when

    $sa1: /scoredAnnotations

    $a1: Annotation() from $sa1.getAnnotation()
    $c1: Compound() from $a1.getCompound()


    $sa2: /scoredAnnotations[ this != $sa1,
                               annotation.labelledFeature != $sa1.annotation.labelledFeature ]
    $a2: Annotation() from $sa2.getAnnotation()
    $c2: Compound() from $a2.getCompound()


    eval( $c1.getLogp() > $c2.getLogp() && $a1.getAnnotationRT() > $a2.getAnnotationRT() )
then
    // Usamos el setter de Java directamente, SIN usar modify()
    $sa1.setScoreRT(1.0);
    $sa2.setScoreRT(1.0);
    System.out.println("Drools Stage 5: Positive evidence between " + $sa1.getAnnotation().getCompound().getName() + " and " + $sa2.getAnnotation().getCompound().getName());
end

rule "Elution Order: Negative Evidence"
when
    $sa1: /scoredAnnotations
    $a1: Annotation() from $sa1.getAnnotation()
    $c1: Compound() from $a1.getCompound()

    $sa2: /scoredAnnotations[ this != $sa1,
                               annotation.labelledFeature != $sa1.annotation.labelledFeature ]
    $a2: Annotation() from $sa2.getAnnotation()
    $c2: Compound() from $a2.getCompound()

    // Si el logP es mayor pero el RT es menor -> Penalización
    eval( $c1.getLogp() > $c2.getLogp() && $a1.getAnnotationRT() < $a2.getAnnotationRT() )
then
    $sa1.setScoreRT(0.0);
    $sa2.setScoreRT(0.0);
    System.out.println("Drools Stage 5: Negative evidence between " + $sa1.getAnnotation().getCompound().getName() + " and " + $sa2.getAnnotation().getCompound().getName());
end

query GetFinalScoredAnnotations
    $sa: /scoredAnnotations
end